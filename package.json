    "lint:client": "pnpm nx lint client",
    "lint:admin": "pnpm nx lint admin",
    "dev:client": "pnpm nx serve client --port 4000",
    "dev:admin": "pnpm nx serve admin --port 4100",
    "build:client": "pnpm nx build client",
    "build:admin": "pnpm nx build admin",
    "ssr:client": "node dist/apps/client/server/server.mjs",
    "ssr:admin": "node dist/apps/admin/server/server.mjs",
    "prepare": "husky"
  },
